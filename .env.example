# oahs — copy to .env and fill in what you need. Everything here is OPTIONAL:
# `docker compose up -d --build oahs` and `make serve` both work with no .env.

# ---------------------------------------------------------------------------
# Spine bootstrap (`oahs serve`, the `oahs` compose service)
# ---------------------------------------------------------------------------
# LEAVE UNSET unless you want a STABLE credential: serve generates a random admin
# token on each start and prints it (`docker compose logs oahs`, or stdout for
# `make serve`) — paste that into /ui to log in. Setting a guessable value here is
# the one easy way to make the spine unsafe: the compose port is published on
# 127.0.0.1 only, but this token is the ONLY thing between a caller and admin.
# OAHS_ADMIN_TOKEN=
OAHS_PORT=4521

# ---------------------------------------------------------------------------
# Model gateway (Phase 6, roadmap §2.5)
# ---------------------------------------------------------------------------
# A RUNTIME-LAYER service: the deterministic spine never imports or calls it
# (§0.1, CI-enforced). Only the agent-cmd / runner side uses it. Under the
# `runtime` profile these are loaded by the DISPATCHER, which forwards OAHS_MODEL_*
# to the AGENT child inside each container — never to the spine, never into a
# container's scoped-token env.
OAHS_MODEL_BASE_URL=https://your-openai-compatible-router/v1
OAHS_MODEL_API_KEY=sk-...
OAHS_MODEL_DEFAULT=cc/claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# Container dispatcher (roadmap §10.2) — the `runtime` compose profile:
#   docker compose --profile runtime up -d --build dispatcher
# The dispatcher is the ONLY holder of the docker socket and the model keys. It
# claims on the host and runs each claim in a one-shot container that receives a
# job-scoped, mutation-only token and nothing else (§10.1/§10.3).
# ---------------------------------------------------------------------------

# The dispatcher's identity on the spine: a runner actor's token (`oahs actor
# create` + `oahs grant`). This STATIC token never enters a container — the
# dispatcher mints a per-claim scoped token for that.
OAHS_RUNNER_TOKEN=

# ABSOLUTE path to the project checkout ON THE HOST — the host's path, not a path
# inside the dispatcher container: docker-out-of-docker means the per-claim
# `docker run -v` bind is resolved by the host daemon. `oahs dispatch` refuses an
# empty value rather than silently mounting its own working directory.
OAHS_REPO_PATH=

# Spec folder relative to the repo root (where stories.yaml + stories/ live).
OAHS_SPEC_FOLDER=delivery/main

# The coding-agent command run INSIDE each container. Placeholders:
# {SPEC_FOLDER} {STORY_ID} {INVOKE_WITH} {WORKTREE}.
OAHS_AGENT_CMD=echo no-agent

# Optional: an npm package baked into the agent-runtime image as the coding agent
# (build-arg AGENT_NPM of apps/oahs/Dockerfile.runner), e.g. @anthropic-ai/claude-code.
OAHS_AGENT_NPM=

# ---------------------------------------------------------------------------
# Git credentials (roadmap §10.3 / §9.6)
# ---------------------------------------------------------------------------
# Claim-scoped push credential. `oahs dispatch` uses it on the HOST (so the agent
# container never receives a push credential at all); BYO `oahs work` presents it
# through a per-dispatch GIT_ASKPASS broker. Ideally short-lived and authorized for
# refs/heads/claim/* only. Unset → your ambient git credential helper pushes,
# unchanged.
OAHS_PUSH_TOKEN=

# Forge API token for PR-on-dispatch (§9.6, BYO `oahs work`). The spine NEVER sees
# this — it lives only in the runner/CLI environment.
OAHS_GITHUB_TOKEN=
