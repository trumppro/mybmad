# oahs model gateway (Phase 6 §2.5) — copy to .env and fill in.
# The gateway is a RUNTIME-LAYER service: the deterministic spine never imports
# or calls it (roadmap §0.1 lint invariant). Only agent-cmd / runner side uses it.
OAHS_MODEL_BASE_URL=https://your-openai-compatible-router/v1
OAHS_MODEL_API_KEY=sk-...
OAHS_MODEL_DEFAULT=cc/claude-haiku-4-5-20251001

# oahs serve / docker-compose — the spine bootstrap.
# OAHS_ADMIN_TOKEN is the bootstrap admin credential (paste it into /ui to log
# in). OAHS_PORT is the HTTP port for both `make serve` and the container.
OAHS_ADMIN_TOKEN=change-me
OAHS_PORT=4521
